// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-p": "file_finder::Toggle",
      "alt-shift-f": null,
      "ctrl-shift-f": null,
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "alt-shift-j": "editor::DuplicateLineDown",
      "alt-shift-l": "editor::SelectLargerSyntaxNode",
      "alt-shift-h": "editor::SelectSmallerSyntaxNode",
      "alt-ctrl-j": "editor::AddSelectionBelow",
      "alt-ctrl-k": "editor::AddSelectionAbove",
      "alt-ctrl-l": "editor::SelectNext",
      "ctrl-shift-alt-j": "debugger::StepOver",
      "ctrl-shift-alt-k": "debugger::Continue",
      "ctrl-shift-alt-h": "debugger::StepOut",
      "ctrl-shift-alt-l": "debugger::StepInto",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-j": "editor::ContextMenuNext",
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-l": "pane::ActivateNextItem",
      "ctrl-n": null,
      "ctrl-p": null,
      "up": null,
      "down": null,
      "left": null,
      "right": null,
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "U": "editor::Redo",
      "g l": "editor::MoveToEndOfLine",
      "g h": "editor::MoveToBeginningOfLine",
      "g m": "editor::MoveToEnclosingBracket",
      "g s": "project_symbols::Toggle",
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-l": "pane::ActivateNextItem",
      "space n s": "buffer_search::Dismiss",
      "space f u": "editor::FindAllReferences",
      "space g i": "editor::GoToImplementation",
      "space f f": "workspace::NewSearch",
      "space r e": "editor::Rename",
      "space z c": "editor::FoldAll",
      "space z o": "editor::UnfoldAll",
      "space s s": "zed::OpenSettings",
      "space a o": "editor::SelectAllMatches",
      "space r p": ["buffer_search::Deploy", { "replace_enabled": true }],
      "space o e": "pane::RevealInProjectPanel",
      "space s p": "pane::RevealInProjectPanel",
      "space t a": "command_palette::Toggle",
      "space f d": "editor::Format",
      "space o i": "editor::OrganizeImports",
      "space o p": "project_panel::ToggleFocus",
      "space o f": "project_search::ToggleFocus",
      "space o t": "terminal_panel::ToggleFocus",
      "space o d": "debug_panel::Toggle",
      "space o c": "git_panel::Toggle",
      "space o s": "projects::OpenRecent",
      "space h w": "workspace::ToggleZoom",
      "space f s": "outline::Toggle",
      "space p i": "editor::ShowSignatureHelp",
      "space r f": "editor::ToggleCodeActions",
      "space n e": "editor::GoToDiagnostic",
      "space p e": "editor::GoToPreviousDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",
      "space d a": "debugger::Start",
      "space s a": "debugger::Stop",
      "space t b": "editor::ToggleBreakpoint",
      "space e e": "debugger::EvaluateSelectedText",
      "space t c": "pane::CloseActiveItem",
      "space t o": "pane::CloseOtherItems",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w h": "workspace::ActivatePaneLeft",
      "space w l": "workspace::ActivatePaneRight",
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",
      "space w c": "pane::CloseActiveItem",
      "up": null,
      "down": null,
      "left": null,
      "right": null,
      "ctrl-n": null,
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "g l": "editor::MoveToEndOfLine",
      "g h": "editor::MoveToBeginningOfLine",
      "g m": "editor::MoveToEnclosingBracket",
      "up": null,
      "down": null,
      "left": null,
      "right": null,
    },
  },
]
