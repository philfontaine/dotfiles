  "copyOnSelect": false,
  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "disableAnimations": true,
  "keybindings": [
    { "keys": "ctrl+c", "id": "Terminal.CopyToClipboard" },
    { "keys": "ctrl+v", "id": "Terminal.PasteFromClipboard" },
    { "keys": "ctrl+h", "command": "prevTab" },
    { "keys": "ctrl+l", "command": "nextTab" },
    { "keys": "ctrl+t", "command": "newTab" },
    { "keys": "ctrl+r", "command": { "action": "splitPane", "split": "right" } },
    { "keys": "ctrl+j", "command": { "action": "splitPane", "split": "down" } },
    { "keys": "alt+shift+h", "command": { "action": "moveFocus", "direction": "left" } },
    { "keys": "alt+shift+j", "command": { "action": "moveFocus", "direction": "down" } },
    { "keys": "alt+shift+k", "command": { "action": "moveFocus", "direction": "up" } },
    { "keys": "alt+shift+l", "command": { "action": "moveFocus", "direction": "right" } },
    { "keys": "ctrl+w", "command": "closePane" },
    { "keys": "ctrl+shift+alt+h", "command": { "action": "resizePane", "direction": "left" } },
    { "keys": "ctrl+shift+alt+j", "command": { "action": "resizePane", "direction": "down" } },
    { "keys": "ctrl+shift+alt+k", "command": { "action": "resizePane", "direction": "up" } },
    { "keys": "ctrl+shift+alt+l", "command": { "action": "resizePane", "direction": "right" } }
  ],
  "launchMode": "maximized",
  "newTabMenu": [],
